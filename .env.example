# ==============================================================================
# CriticAI Environment Variables Configuration Template
# Copy this file to .env and fill in your keys. Do NOT commit .env to Git!
# ==============================================================================

# 🔑 LLM API Key (Required for model execution)
# Get your API key from https://openrouter.ai/keys
# CriticAI uses 'openrouter/free' (e.g. Llama 3) for zero-cost execution.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 🔍 Tavily Search API Key (Optional, for web search tool capabilities)
# Get your key from https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# 🛡️ Security Configurations (Optional, highly recommended for production/sharing)
# CRITICAI_SESSION_SECRET: Used to sign user session IDs to prevent session hijacking.
# If omitted, the server will generate a new random secret on startup.
# CRITICAI_SESSION_SECRET=a_long_random_hex_string_here

# CRITICAI_BACKEND_TOKEN: If set, protects backend API endpoints and WebSockets.
# The client must provide this token in settings to access the backend.
# CRITICAI_BACKEND_TOKEN=your_custom_backend_access_token_here

# 📈 LangSmith Observability/Tracing (Optional, for debugging agent flows)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=CriticAI
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
