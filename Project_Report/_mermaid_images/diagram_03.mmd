flowchart TD
    ROOT["🚀 CriticAI: Dynamic Multi-Agent System"]

    subgraph Design["WP1: System & State Design"]
        WP1A["1.1 Define SwarmState TypedDict<br>(task_prompt, execution_plan,<br>deliverables, agent_statuses,<br>feedback fields, messages)"]
        WP1B["1.2 Define WorkerState TypedDict<br>(agent_role, task_description,<br>guidelines_path, feedback)"]
        WP1C["1.3 Design Custom Reducers<br>(_merge_dicts for deliverables,<br>operator.ior for agent_statuses,<br>add_messages for messages)"]
        WP1D["1.4 Define Pydantic Schemas<br>(Assignment model with reasoning,<br>action_type Literal, OrchestratorPlan)"]
    end

    subgraph Backend["WP2: Backend Engine"]
        WP2A["2.1 Orchestrator Node<br>(Groq LLaMA 3.3 70B,<br>structured output, few-shot<br>chain-of-thought prompting)"]
        WP2B["2.2 Worker Node<br>(Local LM Studio LLM,<br>brand guidelines injection,<br>previous_output context)"]
        WP2C["2.3 Send API Fan-Out<br>(assign_workers conditional edge,<br>parallel worker dispatch)"]
        WP2D["2.4 Feedback Router<br>(route_feedback: targeted Send,<br>global re-orchestration, approval)"]
        WP2E["2.5 Graph Compilation<br>(SqliteSaver checkpointer,<br>interrupt_before=['hitl'],<br>StateGraph.compile())"]
        WP2F["2.6 Legacy Pipeline Nodes<br>(copywriter, art_director,<br>reviewer, exporter — retained<br>for backward compatibility)"]
    end

    subgraph Server["WP3: FastAPI Server Layer"]
        WP3A["3.1 POST /api/start Endpoint<br>(multipart form, file upload,<br>pdf/txt extraction, invoke graph)"]
        WP3B["3.2 POST /api/feedback Endpoint<br>(feedback injection via update_state,<br>resume graph with invoke(None))"]
        WP3C["3.3 GET /api/sessions/id Endpoint<br>(state snapshot retrieval,<br>deliverables & plan exposure)"]
        WP3D["3.4 CORS Middleware<br>(React Vite origin whitelist,<br>all methods & headers allowed)"]
    end

    subgraph Frontend["WP4: React Frontend Application"]
        WP4A["4.1 Session Management<br>(UUID generation, localStorage<br>persistence, session sidebar)"]
        WP4B["4.2 Main Orchestrator Chat<br>(message list, draft rendering,<br>Approve All / Global Revise buttons)"]
        WP4C["4.3 Swarm Loading Visualizer<br>(LoadingSkeleton component,<br>agent status badges with<br>amber/emerald pulse animation)"]
        WP4D["4.4 Focused Canvas View<br>(per-agent full-page markdown,<br>ReactMarkdown + remark-gfm,<br>targeted revision input bar)"]
        WP4E["4.5 File Attachment System<br>(hidden input ref, FormData,<br>animated file badge display)"]
        WP4F["4.6 Framer Motion Animations<br>(AnimatePresence, sidebar<br>slide, message entry, view<br>swap transitions)"]
    end

    subgraph Testing["WP5: Testing & Documentation"]
        WP5A["5.1 Unit Testing<br>(Orchestrator schema validation,<br>router logic, reducer merging)"]
        WP5B["5.2 Integration Testing<br>(FastAPI test client, full<br>start-to-feedback flow)"]
        WP5C["5.3 End-to-End Testing<br>(browser workflow validation,<br>reload session recovery test)"]
        WP5D["5.4 Report & Documentation<br>(Architecture diagrams,<br>API reference, code comments)"]
    end

